{
  "//": "Standalone type-check for the example plugin's JS half. It resolves react and the SDK from the led web workspace so a third party can validate their plugin against @led/plugin-sdk without a full install. Run: npx tsc -p examples/plugin-hello/web/tsconfig.json --noEmit (from web/, or with cwd anywhere).",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@led/plugin-sdk": ["../../../web/src/plugin-sdk"],
      "react": ["../../../web/node_modules/@types/react"],
      "react/jsx-runtime": ["../../../web/node_modules/@types/react/jsx-runtime"],
      "react-dom": ["../../../web/node_modules/@types/react-dom"],
      "react-dom/*": ["../../../web/node_modules/@types/react-dom/*"],
      "react-router-dom": ["../../../web/node_modules/react-router-dom"],
      "framer-motion": ["../../../web/node_modules/framer-motion"],
      "tailwind-merge": ["../../../web/node_modules/tailwind-merge"],
      "lucide-react": ["../../../web/node_modules/lucide-react"]
    }
  },
  "include": ["."]
}
