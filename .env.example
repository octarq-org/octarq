# --- core (required) ---
LED_SECRET_KEY=change-me-to-a-long-random-string   # signs sessions + encrypts provider creds
LED_ADMIN_PASSWORD=change-me                        # dashboard login password
LED_ADMIN_USER=admin

# --- server ---
LED_LISTEN=:8080
# Host that serves the dashboard. Other hosts pointed at led serve short links.
# Leave empty to serve the dashboard on any host (slugs are still tried first).
LED_ADMIN_HOST=

# --- database ---
LED_DB_DRIVER=sqlite        # sqlite | postgres
LED_DB_DSN=led.db           # sqlite: file path | postgres: postgres://user:pass@host:5432/led

# --- short links ---
LED_BASE_URL=https://go.example.com   # used to build QR / copy URLs when a link has no host

# --- email receiving (Cloudflare Email Routing -> Worker -> webhook) ---
LED_INBOUND_TOKEN=change-me-too   # shared secret the Worker sends as X-Led-Token
LED_CATCH_ALL=true                # auto-create a mailbox for unknown recipients on mail domains

# --- email sending (optional SMTP relay) ---
LED_SMTP_HOST=
LED_SMTP_PORT=587
LED_SMTP_USER=
LED_SMTP_PASS=
LED_SMTP_FROM=

# --- analytics (optional) ---
LED_GEOIP_DB=        # path to a MaxMind GeoLite2-City.mmdb for country/city resolution
