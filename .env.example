# --- core (required) ---
LED_SECRET_KEY=change-me-to-a-long-random-string   # signs sessions + encrypts provider creds
LED_ADMIN_PASSWORD=change-me                        # dashboard login password
LED_ADMIN_USER=admin

# --- server ---
LED_LISTEN=:8080
# Docker only: host port published by docker-compose. Change if 8080 is taken.
LED_PORT=8080
# Restrict the dashboard (/admin) to this host. Empty = served on any host.
LED_ADMIN_HOST=

# --- database ---
LED_DB_DRIVER=sqlite        # sqlite | postgres
LED_DB_DSN=led.db           # sqlite: file path | postgres: postgres://user:pass@host:5432/led

# --- analytics (optional) ---
LED_GEOIP_DB=        # path to a MaxMind GeoLite2-City.mmdb for country/city resolution

# --- AI / LLM (optional; used by Pro Inbox-AI; `led mcp` tools themselves need no LLM) ---
# In the Pro build this is configured from the dashboard (Inbox AI → Configure);
# these env vars are the fallback.
LED_LLM_PROVIDER=claude   # claude | openai | gemini | mistral | cohere | ollama
LED_LLM_API_KEY=          # cloud key; for claude falls back to ANTHROPIC_API_KEY
LED_LLM_MODEL=            # override reasoning model (per-provider default if blank)
LED_LLM_CHEAP_MODEL=      # override cheap classification model (per-provider default if blank)
LED_LLM_BASE_URL=         # OpenAI-compatible gateway / proxy / local Ollama address

# --- MCP server (`led mcp`) ---
LED_MCP_ORG_ID=1          # tenant the read-only tools are scoped to
