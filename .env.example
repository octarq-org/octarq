# --- core (required) ---
OCTARQ_SECRET_KEY="<generate-with: openssl rand -hex 32>"   # signs sessions + encrypts provider creds
OCTARQ_ADMIN_PASSWORD="<your-strong-password>"                        # dashboard login password
OCTARQ_ADMIN_USER=admin

# --- server ---
OCTARQ_LISTEN=:8080
# Docker only: host port published by docker-compose. Change if 8080 is taken.
OCTARQ_PORT=8080
# Restrict the dashboard (/admin) to this host. Empty = served on any host.
OCTARQ_ADMIN_HOST=
# Honour X-Forwarded-For / X-Real-IP for the client IP (rate limiting, abuse).
# Enable ONLY behind a trusted reverse proxy; otherwise clients can spoof it.
# OCTARQ_TRUST_PROXY=false
# Allow operator-configured webhook / notification targets to reach private or
# loopback addresses. Off by default (blocks SSRF); enable only when your webhook
# receivers run on a trusted internal network.
# OCTARQ_ALLOW_PRIVATE_WEBHOOKS=false
# Public-facing URL, used to build OAuth callback URIs (e.g. https://app.example.com).
# Leave empty to disable OAuth login.
# OCTARQ_BASE_URL=
# Add the Secure attribute to the session cookie (HTTPS-only). Auto-enabled when
# the deployment looks production (https OCTARQ_BASE_URL or OCTARQ_ADMIN_HOST set);
# set explicitly to force it on/off.
# OCTARQ_SECURE_COOKIES=true

# --- database ---
OCTARQ_DB_DRIVER=sqlite        # sqlite | postgres
OCTARQ_DB_DSN=octarq.db           # sqlite: file path | postgres: postgres://user:pass@host:5432/octarq
# Optional Redis for rate limiting / caching (e.g. redis://localhost:6379).
# Empty = Redis-based features fall back to DB / in-memory.
# OCTARQ_REDIS_URL=

# --- analytics (optional) ---
# Path to a MaxMind GeoLite2-City.mmdb for country/city resolution. Empty = geo
# columns stay blank (everything else works). How to obtain + Docker/k8s wiring:
# deploy/GEOIP.md
OCTARQ_GEOIP_DB=
# Easiest path: leave OCTARQ_GEOIP_DB empty and set a free MaxMind license key
# (maxmind.com → Account → Manage License Keys); octarq then auto-downloads
# GeoLite2-City at startup into the data dir (next to the sqlite db) and keeps
# using that file on later starts. Precedence: OCTARQ_GEOIP_DB > already
# downloaded file > this key > geo disabled.
OCTARQ_MAXMIND_LICENSE_KEY=

# --- AI / LLM (optional; powers the built-in AI assists — slug suggestions,
# on-demand email summary — and the Pro Inbox-AI; `octarq mcp` tools themselves need no LLM) ---
# In the Pro build this is configured from the dashboard (Inbox AI → Configure);
# these env vars are the fallback.
OCTARQ_LLM_PROVIDER=claude   # claude | openai | gemini | mistral | cohere | ollama
OCTARQ_LLM_API_KEY=          # cloud key; for claude falls back to ANTHROPIC_API_KEY
OCTARQ_LLM_MODEL=            # override reasoning model (per-provider default if blank)
OCTARQ_LLM_CHEAP_MODEL=      # override cheap classification model (per-provider default if blank)
OCTARQ_LLM_BASE_URL=         # OpenAI-compatible gateway / proxy / local Ollama address

